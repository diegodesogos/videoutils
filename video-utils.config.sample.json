{
  "profiles": {
    "sample-workflow": [
      {
        "command": "convert",
        "sourceDirOrFile": "./input",
        "outputDir": "./output",
        "options": {
          "dryRun": true,
          "recursive": true
        }
      },
      {
        "command": "adjust-exif",
        "targetDirOrFile": "./output",
        "options": {
          "compareDate": "distinct",
          "syncFS": true,
          "dryRun": true,
          "applyHeuristics": true
        }
      },
      {
        "command": "inspect",
        "targetDirOrFile": "./output",
        "options": {
          "minHeight": 720
        }
      },
      {
        "command": "remux",
        "targetDirOrFile": "./output",
        "options": {
          "aspectRatio": "16:9"
        }
      }
    ],
    "dvd": [
      {
        "command": "convert",
        "sourceDirOrFile": "./input",
        "outputDir": "./output",
        "options": {
          "dryRun": true
        }
      }
    ]
  }
}